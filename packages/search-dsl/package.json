{
  "name": "@elastic/elasticsearch-search-dsl",
  "version": "0.0.1",
  "description": "Elasticsearch Search DSL for JavaScript/TypeScript",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src test",
    "lint:fix": "biome check --write src test",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elastic/elasticsearch-dsl-js.git",
    "directory": "packages/search-dsl"
  },
  "keywords": [
    "elasticsearch",
    "elastic",
    "search",
    "dsl",
    "typescript"
  ],
  "author": "Elastic",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/elastic/elasticsearch-dsl-js/issues"
  },
  "homepage": "https://github.com/elastic/elasticsearch-dsl-js/tree/main/packages/search-dsl#readme",
  "peerDependencies": {
    "@elastic/elasticsearch": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "@elastic/elasticsearch": {
      "optional": true
    }
  }
}
