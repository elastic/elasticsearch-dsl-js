{
  "name": "@elastic/elasticsearch-dsl",
  "version": "0.1.0",
  "description": "",
  "main": "./lib",
  "types": "./lib",
  "author": {
    "name": "Tomas Della Vedova",
    "company": "Elastic BV"
  },
  "license": "Apache-2.0",
  "scripts": {
    "prebuild": "npm run lint && npm run build:clean",
    "build": "tsc",
    "build:clean": "rm -rf lib && mkdir lib",
    "lint": "standard **/*.ts",
    "prepublishOnly": "npm run build",
    "test": "npm run build && tap test/**/*.ts --no-coverage",
    "test:coverage": "npm run build && tap test/**/*.ts --coverage-report=html",
    "example": "ts-node"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elastic/elasticsearch-dsl-js.git"
  },
  "keywords": [],
  "bugs": {
    "url": "https://github.com/elastic/elasticsearch-dsl-js/issues"
  },
  "homepage": "https://github.com/elastic/elasticsearch-dsl-js#readme",
  "dependencies": {
    "deepmerge": "^3.2.0"
  },
  "devDependencies": {
    "@elastic/elasticsearch": "^7.0.0-rc.2",
    "@types/node": "^11.13.7",
    "@typescript-eslint/eslint-plugin": "^1.7.0",
    "@typescript-eslint/parser": "^1.7.0",
    "minimist": "^1.2.0",
    "simple-git": "^1.110.0",
    "standard": "^12.0.1",
    "tap": "^13.0.1",
    "ts-node": "^8.1.0",
    "typescript": "^3.4.5"
  },
  "standard": {
    "parser": "@typescript-eslint/parser",
    "plugins": [
      "@typescript-eslint"
    ],
    "ignore": [
      "lib"
    ]
  }
}
