  },
  "homepage": "https://github.com/elastic/elasticsearch-dsl-js#readme",
  "devDependencies": {
    "@elastic/elasticsearch": "^7.3.0",
    "@types/node": "^12.6.9",
    "@typescript-eslint/eslint-plugin": "^1.13.0",
    "@typescript-eslint/parser": "^1.13.0",
    "es-client-5": "npm:@elastic/elasticsearch@^5.6.20",
    "es-client-6": "npm:@elastic/elasticsearch@^6.8.2",
    "es-client-7": "npm:@elastic/elasticsearch@^7.3.0",
    "execa": "^2.0.3",
    "minimist": "^1.2.0",
    "simple-git": "^1.124.0",
    "split2": "^3.1.1",
    "standard": "^13.1.0",
    "stoppable": "^1.1.0",
    "tap": "^14.6.1",
    "ts-node": "^8.3.0",
    "typescript": "^3.5.3"
  },
  "standard": {
    "parser": "@typescript-eslint/parser",
    "plugins": [
      "@typescript-eslint"
    ],
    "ignore": [
      "lib"
    ]
