    "prepublishOnly": "npm run build",
    "test": "npm run lint && tap test/**/*.test.ts --no-coverage",
    "test:coverage": "tap test/**/*.ts --coverage-report=html",
    "example": "ts-node"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elastic/elasticsearch-dsl-js.git"
  },
  "keywords": [],
