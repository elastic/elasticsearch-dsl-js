{
  "name": "@elastic/elasticsearch-dsl",
  "version": "0.0.1",
  "description": "Elasticsearch DSL query builder for JavaScript/TypeScript",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "biome check src test",
    "lint:fix": "biome check --write src test",
    "format": "biome format --write src test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist coverage",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build",
    "license-checker": "license-checker --production --onlyAllow 'MIT;Apache-2.0;Apache1.1;ISC;BSD-3-Clause;BSD-2-Clause;0BSD'",
    "check-spdx": "node scripts/check-spdx.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elastic/elasticsearch-dsl-js.git"
  },
  "keywords": [
    "elasticsearch",
    "elastic",
    "search",
    "query",
    "dsl",
    "query-builder",
    "typescript"
  ],
  "author": "Elastic",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/elastic/elasticsearch-dsl-js/issues"
  },
  "homepage": "https://github.com/elastic/elasticsearch-dsl-js#readme",
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@elastic/elasticsearch": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "@elastic/elasticsearch": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@elastic/elasticsearch": "^9.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@vitest/ui": "^3.0.0",
    "license-checker": "^25.0.0",
    "rimraf": "^6.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
